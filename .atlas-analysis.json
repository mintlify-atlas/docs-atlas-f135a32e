  "keyFeatures": [
    "Declarative YAML agent configuration with versioned schema (v0-v7)",
    "Multi-agent orchestration with coordinator and specialized sub-agents",
    "Rich built-in tool ecosystem (filesystem, shell, memory, think, RAG, and more)",
    "MCP (Model Context Protocol) server support — local, remote, and Docker-based",
    "AI provider agnostic — OpenAI, Anthropic, Gemini, AWS Bedrock, Docker Model Runner, and more",
    "Interactive TUI for live sessions and --exec mode for scripting/pipelines",
    "Package and share agents via OCI registries (like container images)",
    "MCP server mode — expose agents as MCP tools for other clients",
    "Agent-to-Agent (A2A) protocol support for interoperable multi-agent systems",
    "RAG with BM25, embeddings, hybrid search, and reranking",
    "Skills system for reusable agent behavior and tool instruction injection",
    "Sandboxed execution via Docker Desktop sandbox integration",
    "Hooks for lifecycle events (session start/stop, tool calls, post-edit)",
    "HTTP API server mode for programmatic integration"
  ],
  "publicApiSurface": [
    "docker agent run [<agent-file>|<registry-ref>] [message]",
    "docker agent run --exec <agent-file> [message] (non-interactive)",
    "docker agent new [--model provider/model]",
    "docker agent share push <agent.yaml> <namespace/repo>",
    "docker agent share pull <namespace/repo>",
    "docker agent serve mcp <agent.yaml>",
    "docker agent serve a2a <agent.yaml>",
    "docker agent serve api",
    "docker agent eval <agent.yaml>",
    "docker agent debug auth",
    "docker-agent run --agent <name> (select agent from multi-agent config)",
    "docker-agent run --model provider/model (override model at runtime)",
    "docker-agent run --yolo (auto-approve all tool calls)",
    "docker-agent run --sandbox (run inside Docker sandbox)",
    "docker-agent run --session <id> (resume previous session)",
    "docker-agent run --remote <address> (use remote runtime)"
  ]
}
